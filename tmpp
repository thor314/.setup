function gityeet
  git add --all . --verbose
  git commit -m $1
  git push
end
function gityeeet # new branch
  git add --all . --verbose
  git commit -m $1
  git push --set-upstream origin $(git_current_branch)
end
function gityeeeet # new repo
  hub create
  gityeeet $1
end

